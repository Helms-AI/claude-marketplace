{
  "description": "DevOps plugin hooks - deployment safety, infrastructure validation, CI/CD checks, observability telemetry",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-devops-command.sh",
            "timeout": 10,
            "statusMessage": "Validating DevOps command..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/telemetry/pre-tool-monitor.sh",
            "timeout": 5,
            "statusMessage": "Capturing telemetry..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-infra-changes.sh",
            "timeout": 10,
            "statusMessage": "Validating infrastructure changes..."
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/telemetry/post-tool-monitor.sh",
            "timeout": 5,
            "statusMessage": "Recording telemetry..."
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/telemetry/subagent-start-monitor.sh",
            "timeout": 5,
            "statusMessage": "Tracking agent invocation..."
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/devops-summary.sh",
            "timeout": 10,
            "statusMessage": "Generating DevOps summary..."
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/telemetry/subagent-stop-monitor.sh",
            "timeout": 5,
            "statusMessage": "Recording agent completion..."
          }
        ]
      }
    ]
  }
}
